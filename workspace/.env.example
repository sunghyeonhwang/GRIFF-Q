# ============================================
# GRIFF-Q 0.1 환경변수
# 이 파일을 .env.local로 복사하여 실제 값을 채워 사용
# cp workspace/.env.example .env.local
# ============================================

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Supabase 대시보드 → Settings → API 에서 확인

# ---- Supabase DB (직접 접속용 — 마이그레이션/백업) ----
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# ---- Google Gemini API (클라이언트 반응 예측) ----
GEMINI_API_KEY=AIzaSyA3qOiDVn0ckaEoOxrxS6_Ut3PQKN1XSZ8
# https://aistudio.google.com/apikey 에서 발급

# ---- Google Sheets API (회의록/견적서 퍼블리시) ----
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Google Cloud Console → IAM → 서비스 계정 → JSON 키에서 추출

# ---- 앱 설정 ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
# 프로덕션: https://your-domain.com

# ---- Vercel (Preview/Staging 배포 시 자동 설정) ----
# VERCEL_URL — Vercel이 자동 주입
# VERCEL_ENV — Vercel이 자동 주입 (production/preview/development)
